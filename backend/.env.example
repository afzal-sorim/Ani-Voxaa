# # ─────────────────────────────────────────────────────────
# # VOXA — Backend Environment Variables
# # Copy this file to .env and fill in your values.
# # ─────────────────────────────────────────────────────────

# # Groq API Key (FREE — get yours at https://console.groq.com)
# GROQ_API_KEY=your_groq_api_key_here

# # LLM Model Configuration
# # Primary: Mistral | Fallback: LLaMA 3
# PRIMARY_MODEL=llama-3.3-70b-versatile
# FALLBACK_MODEL=llama-3.1-8b-instant

# # Whisper Model Size (base.en, small.en, medium.en)
# WHISPER_MODEL=base.en

# # Server Configuration
# HOST=0.0.0.0
# PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# # Data paths
# DATA_DIR=../data
# DATA_BACKEND=local

# # Optional: MongoDB Atlas backend (used when DATA_BACKEND=mongo)
# MONGO_URI=
# MONGO_DB_NAME=voxa
# MONGO_USERS_COLLECTION=users
# MONGO_CHATS_COLLECTION=chats

# # Optional: object storage for uploads/profile pics
# # STORAGE_BACKEND: local | supabase
# STORAGE_BACKEND=local

# # Supabase Storage (set STORAGE_BACKEND=supabase)
# SUPABASE_URL=https://bblwxriogxhwxvjxqwmi.supabase.co
# SUPABASE_KEY=sb_publishable_bilABx7cSKdyCx3c3Cne5Q_Cfjx6ak2
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_PUBLIC_BASE_URL=

# # JWT Secret (change for production!)
# JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_HOURS=24
